# App
PORT=3000
API_KEY=change-me-to-a-strong-secret
TOR_SOCKS_ADDR=tor:9050
MAX_CONCURRENCY=5
TIMEOUT=45s

# Database (used by both postgres service and api)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=verifier
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=verifier
DB_SSLMODE=disable
# Optional full override. Leave empty to build from DB_* values.
DATABASE_DSN=

# Webhook
WEBHOOK_URL=
WEBHOOK_TIMEOUT=10s

# Scheduling
CHECK_INTERVAL=1m
FIRST_BOUNCE_DELAY=2m
SECOND_BOUNCE_DELAY=6h
