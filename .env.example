# App
PORT=3000
WEB_PORT=8080
API_KEY=change-me-to-a-strong-secret
MAX_CONCURRENCY=10
TIMEOUT=20s
VERIFIER_MAIL_FROM=verify@verifier.local
VERIFIER_EHLO_DOMAIN=verifier.local
DELIVERABLE_TTL=168h
UNDELIVERABLE_TTL=24h
ACCEPT_ALL_TTL=24h
UNKNOWN_TTL=6h
DOMAIN_BASELINE_TTL=24h
ENRICHMENT_WORKERS=2

# Image source for deploy/docker-compose.prod.yml (GitHub Actions builds and pushes here)
# Format: ghcr.io/<github-owner>/<repo-name-without-.git>
GHCR_IMAGE_PREFIX=ghcr.io/hasib105/email-verifier

# Database (used by both postgres service and api)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=verifier
DB_HOST=postgres
DB_PORT=15432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=verifier
DB_SSLMODE=disable
# Optional full override. Leave empty to build from DB_* values.
DATABASE_DSN=

# Optional: values below are only used if you run deploy/set-github-secrets.ps1
# to upload server/deploy secrets automatically. Do not commit real values.
SERVER_HOST=
SERVER_USER=
SERVER_PASSWORD=
SERVER_SSH_PORT=22
SERVER_APP_DIR=/opt/email-verifier-api

# GHCR credentials are auto-taken by GitHub Actions deploy workflow:
# username = github.actor, token = github.token
